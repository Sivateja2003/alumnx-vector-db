# Google Gemini API key — get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# PostgreSQL connection URL (Default for Docker: postgresql://postgres:password@db:5432/vectordb)
# Use 'db' as the host inside Docker, use 'localhost' for local development without Docker.
POSTGRES_URL=postgresql://postgres:password@db:5432/vectordb

# Optional: Overrides for Docker services (Defaults are already set in docker-compose.yml)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=vectordb
# CONTAINER_NAME=alumnx-vector-db
